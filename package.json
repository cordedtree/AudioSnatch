{
  "name": "audiosnatch",
  "version": "1.3.3",
  "description": "Universal audio downloader — grab audio from YouTube, SoundCloud, TikTok, and 1000+ sites",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --dir && node scripts/patch-icon.js && electron-builder --prepackaged dist/win-unpacked"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.audiosnatch.app",
    "productName": "AudioSnatch",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "icon.ico"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Cordedtree",
      "repo": "AudioSnatch"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
