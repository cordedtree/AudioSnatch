{
  "name": "audiosnatch",
  "version": "1.2.1",
  "description": "Universal audio downloader — grab audio from YouTube, SoundCloud, TikTok, and 1000+ sites",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.audiosnatch.app",
    "productName": "AudioSnatch",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "Cordedtree",
      "repo": "AudioSnatch"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
